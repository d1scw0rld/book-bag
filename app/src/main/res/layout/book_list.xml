<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
   android:layout_width="match_parent"
   android:layout_height="match_parent"
   android:clipToPadding="false"
   android:orientation="vertical" >

   <RelativeLayout
      android:id="@+id/ll_fields"
      android:layout_width="match_parent"
      android:layout_height="?attr/actionBarSize"
      android:layout_marginTop="@dimen/margin_minus_tiny"
      android:elevation="@dimen/elevation_standard"
      android:outlineProvider="bounds"
      android:paddingTop="@dimen/padding_tiny" >

      <TextView
         android:id="@+id/tv_books_order"
         android:layout_width="match_parent"
         android:layout_height="match_parent"
         android:layout_alignParentStart="true"
         android:layout_gravity="center_horizontal"
         android:background="@color/background_material_light"
         android:gravity="center_vertical"
         android:paddingStart="@dimen/standard_material_padding"
         android:text="order" />
      
      <TextView
         android:id="@+id/tv_books_count"
         android:layout_width="wrap_content"
         android:layout_height="match_parent"
         android:layout_alignParentEnd="true"
         android:layout_gravity="center_horizontal"
         android:background="@color/background_material_light"
         android:gravity="center_vertical"
         android:paddingLeft="@dimen/standard_material_padding"
         android:paddingRight="@dimen/standard_material_padding"
         android:text="153" />

   </RelativeLayout>

   <androidx.recyclerview.widget.RecyclerView
      xmlns:app="http://schemas.android.com/apk/res-auto"
      xmlns:tools="http://schemas.android.com/tools"
      android:id="@+id/book_list"
      android:name="org.d1scw0rld.bookbag.BookListFragment"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:paddingBottom="@dimen/book_list_padding_bottom"
      android:clipToPadding="false"
      app:layoutManager="LinearLayoutManager"
      tools:context="org.d1scw0rld.bookbag.BookListActivity"
      tools:listitem="@layout/book_list_content" />

</LinearLayout>