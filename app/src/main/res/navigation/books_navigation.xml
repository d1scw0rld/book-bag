<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/books_navigation"
    app:startDestination="@id/fragment_book_list">

    <action
        android:id="@+id/action_to_book_list"
        app:popUpTo="@id/fragment_book_list"
        app:popUpToInclusive="false"/>
    <fragment
        android:id="@+id/fragment_book_list"
        android:name="org.d1scw0rld.bookbag.BookListFragment"
        android:label="@string/app_name">
        <action
            android:id="@+id/action_bookListFragment_to_bookFragment"
            app:destination="@id/fragment_book" />
        <action
            android:id="@+id/action_bookListFragment_to_editBookFragment"
            app:destination="@id/fragment_edit_book" />
        <action
            android:id="@+id/action_bookListFragment_to_settingsFragment"
            app:destination="@id/fragment_settings" />
    </fragment>
    <fragment
        android:id="@+id/fragment_book"
        android:name="org.d1scw0rld.bookbag.BookFragment">
        <action
            android:id="@+id/action_bookFragment_to_editBookFragment"
            app:destination="@id/fragment_edit_book" />
        <argument
            android:name="bookID"
            app:argType="long" />
    </fragment>
    <fragment
        android:id="@+id/fragment_edit_book"
        android:name="org.d1scw0rld.bookbag.EditBookFragment"
        tools:layout="@layout/fragment_edit_book">
        <argument
            android:name="bookID"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="isCopy"
            android:defaultValue="false"
            app:argType="boolean" />
    </fragment>
    <fragment
        android:id="@+id/fragment_settings"
        android:name="org.d1scw0rld.bookbag.SettingsFragment"
        android:label="@string/title_settings"/>
</navigation>